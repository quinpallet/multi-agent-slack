{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "aws-lambda"],
    "lib": ["ES2021", "DOM"],
    "outDir": "dist",
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
