{
  "name": "claude-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Slack @mention auto-reply bot (API Gateway -> SQS -> Lambda -> Anthropic -> Slack)",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "esbuild src/receiver.ts src/processor.ts --bundle --platform=node --target=node22 --outdir=dist",
    "package": "npm run build && cd dist && zip -r ../lambda.zip receiver.js processor.js > /dev/null && cd ..",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.14.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  }
}
